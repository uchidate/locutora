# Production credentials and environment-specific configuration
/configuration.php
/.deploy/

# Restored database dumps (may contain users, form submissions, and secrets)
/installation/sql/site.sql
/installation/sql/site.s*

# Runtime-generated data
/cache/*
!/cache/index.html
/tmp/*
!/tmp/index.html
/administrator/cache/*
!/administrator/cache/index.html
/administrator/logs/*
!/administrator/logs/index.html

# Local operating-system and editor files
.DS_Store
**/.DS_Store
*.log
.nfs*
**/.nfs*

# Backup and recovery artifacts
*.jpa
*.jps
*.zip
*.tar
*.tar.gz
*.bak
*.backup
*.backup-*
