	<install>
		<sql>
			<file driver="mysql" charset="utf8">sql/mysql/install.sql</file>
		</sql>
	</install>

	<uninstall>
		<sql>
			<file driver="mysql" charset="utf8">sql/mysql/uninstall.sql</file>
		</sql>
	</uninstall>

	<files>
		<folder>sql</folder>
		<folder>fields</folder>
		<folder>forms</folder>
		<filename plugin="rsfpmailer">rsfpmailer.php</filename>
		<filename>index.html</filename>
	</files>

	<languages folder="language">
		<language tag="en-GB">en-GB/en-GB.plg_system_rsfpmailer.ini</language>
		<language tag="en-GB">en-GB/en-GB.plg_system_rsfpmailer.sys.ini</language>
	</languages>
